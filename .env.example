# ---------------------------------------------------------------------------
# Alien Protocol — RedStone x Stellar integration layer
# Copy this file to `.env` and fill in real values. NEVER commit a real .env.
# ---------------------------------------------------------------------------

# Stellar network to target: testnet | mainnet | custom
NETWORK=testnet

# Soroban RPC endpoint for the selected network.
# Testnet default: https://soroban-testnet.stellar.org
RPC_URL=https://soroban-testnet.stellar.org

# Secret key (S...) of the funded account used to sign deploy / invoke txs.
# Fund a testnet account at https://friendbot.stellar.org
# DO NOT commit a real secret key.
PRIVATE_KEY=S................................................

# Directory where deployed contract id files are written/read.
# Optional — defaults to ./stellar
DEPLOY_DIR=./stellar

# Filesystem path to the compiled RedStone adapter WASM that gets deployed.
# Build it from the RedStone stellar-connector repo (`make build`) and point
# this at the produced `redstone_adapter.wasm`.
# Optional — defaults to ./stellar/target/wasm32v1-none/release/redstone_adapter.wasm
ADAPTER_WASM_PATH=./stellar/target/wasm32v1-none/release/redstone_adapter.wasm

# Pre-deployed adapter contract id. The deploy script WRITES this to
# `stellar/redstone_adapter-id.<network>`; the run script READS it from there.
# You normally do not need to set this manually, but it is supported as an
# override (takes precedence over the saved id file when present).
ADAPTER_CONTRACT_ID=
